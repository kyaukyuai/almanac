.DS_Store
.vscode/
.idea/
*.swp

# Env / secrets
.env
.env.local
.env.*.local

# Stage scratch (pipeline writes intermediates here when targeting a workspace)
.compile/

# Logs
*.log

# Temporary files left by editors or tools
*.tmp
*.tmp.*
*~
